# --- 1minAI Configuration ---
ONEMINAI_API_KEY=your_1minai_api_key
LITELLM_BASE_URL=https://api.1min.ai

# 1minAI Model Mapping (customize which models to expose)
# Format: EXTERNAL_NAME=1MINAI_MODEL_NAME
ONEMINAI_MODEL_GPT4O_MINI=gpt-4o-mini
ONEMINAI_MODEL_GPT4O=gpt-4o
ONEMINAI_MODEL_CLAUDE_SONNET=claude-3-5-sonnet
ONEMINAI_MODEL_CLAUDE_HAIKU=claude-3-haiku
ONEMINAI_MODEL_GEMINI_2_FLASH=gemini-2.0-flash
ONEMINAI_MODEL_GEMINI_15_FLASH=gemini-1.5-flash
ONEMINAI_MODEL_GEMINI_15_PRO=gemini-1.5-pro

# --- Fallback Providers ---
OPENROUTER_API_KEY=sk-or-your-key
OPENROUTER_API_KEY_2= # Optional Backup 1
OPENROUTER_API_KEY_3= # Optional Backup 2
OPENROUTER_MODEL=openrouter/google/gemini-pro-1.5

MISTRAL_API_KEY=your_mistral_key
MISTRAL_API_KEY_2= # Optional Backup 1
MISTRAL_API_KEY_3= # Optional Backup 2
MISTRAL_MODEL=mistral/mistral-large-latest

GEMINI_API_KEY=your_gemini_key
GEMINI_API_KEY_2= # Optional Backup 1
GEMINI_API_KEY_3= # Optional Backup 2
GEMINI_MODEL=gemini/gemini-1.5-pro

# --- Server Config ---
FASTAPI_PORT=9000
FASTAPI_HOST=0.0.0.0

# --- Token Optimization (NEW in v1.1.0) ---
# Limit conversation history to save tokens (default: 20 messages)
MAX_CONTEXT_MESSAGES=20

# Use compact tool descriptions to reduce token usage (default: true)
# true = "Tools: get_weather(location,unit)" (compact)
# false = Full JSON schema with descriptions (verbose)
COMPACT_TOOL_DESCRIPTIONS=true

# --- CORS Configuration ---
# Comma-separated origins, or "*" for all (default: *)
ALLOWED_ORIGINS=*
